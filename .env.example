# AAIN Configuration
AAIN_LOG_LEVEL=INFO
AAIN_API_HOST=0.0.0.0
AAIN_API_PORT=8000

# LLM Provider (mock | claude | openai)
AAIN_LLM_PROVIDER=mock

# Claude API (when using claude provider)
ANTHROPIC_API_KEY=

# OpenAI API (when using openai provider)
